# {
#   "name": "summarizeMovie",
#   "description": "Run frameMovie, frameCompare, and frameUpload in sequence on the given directory (defaults to ~/Downloads/frames)",
#   "usage": "dev summarizeMovie [directory]"
# }
dir=${1:-$HOME/Downloads/frames}

mkdir -p "$dir"

dev frameMovie "$dir" \
    && dev frameCompare "$dir" \
    && dev frameUpload "$dir"
