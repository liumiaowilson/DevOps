# {
#   "name": "frameUpload",
#   "description": "Upload <directory>/summary.txt content to Item__c.Text__c using recordId from meta.json",
#   "usage": "dev frameUpload <directory>"
# }
dir=$1
alias=${2:-$DefaultAlias}

if [ -z "$dir" ]; then
    echo 'Directory is required'
    exit 1
fi

absDir=$(cd "$dir" 2>/dev/null && pwd)
if [ -z "$absDir" ]; then
    echo "Directory does not exist: $dir"
    exit 1
fi

sf mypim run script -o $alias -f ~/DevOps/cb_js/frameUpload.js "$absDir"
