# {
#   "name": "open_chrome",
#   "description": "Open the default org in chrome browser",
#   "usage": "dev open_chrome"
# }
alias=$1

if [ -z $alias ]; then
    alias=$DefaultAlias
fi

url=$(sf org open -o $alias --url-only 2>/dev/null | grep -o 'https://[^ ]*')
echo "$url"
open -a "Google Chrome" "$url"
