# {
#   "name": "deployMyPIM",
#   "description": "Copy git changed files under ~/mypim/src into ~/mypim/build, then deploy the build directory",
#   "usage": "dev deployMyPIM"
# }
srcDir=~/mypim/src
buildDir=~/mypim/build

cd ~/mypim

files=`git status -s -uall -- src | grep -v '^.D' | grep -v '^D' | awk '{print $NF}'`

if [ -z "$files" ]; then
    echo 'No git changed files under src, deploying build directory as-is'
fi

staged=""

for f in $files; do
    rel=${f#src/}

    case $rel in
        objects/*)
            echo "Skipped $rel (object changes are not copied)"
            ;;
        lwc/*/* | aura/*/*)
            bundleType=`echo $rel | cut -d/ -f1`
            bundleName=`echo $rel | cut -d/ -f2`
            bundle=$bundleType/$bundleName

            case " $staged " in
                *" $bundle "*) continue ;;
            esac
            staged="$staged $bundle"

            mkdir -p $buildDir/$bundleType
            cp -R $srcDir/$bundle $buildDir/$bundleType/
            echo "Staged $bundle"
            ;;
        *)
            mkdir -p $buildDir/`dirname $rel`
            cp $srcDir/$rel $buildDir/$rel
            echo "Staged $rel"

            if [ -f $srcDir/$rel-meta.xml ]; then
                cp $srcDir/$rel-meta.xml $buildDir/$rel-meta.xml
            fi

            base=${rel%-meta.xml}
            if [ "$base" != "$rel" ] && [ -f $srcDir/$base ]; then
                cp $srcDir/$base $buildDir/$base
            fi
            ;;
    esac
done

cd $buildDir
dev deploy .

if [ $? -ne 0 ]; then
    echo 'Deploy failed, skipping build cleanup'
    exit 1
fi

echo 'Cleaning build directory'

for dir in $buildDir/*/; do
    dirName=`basename $dir`

    for entry in $dir*; do
        [ -e "$entry" ] || continue
        name=`basename $entry`

        if [ "$dirName" = "lwc" ]; then
            case $name in
                mypimItemTypes | mypimEventSeedEngine | mypimRecordSearchPanel)
                    continue
                    ;;
            esac
        fi

        rm -rf "$entry"
        echo "Removed $dirName/$name"
    done
done
