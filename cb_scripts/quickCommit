# {
#   "name": "quickCommit",
#   "description": "Stage all changes and commit with an auto-generated message. Optional free-form guidance steers style, tone, or staging (e.g., 'be terse', 'use conventional commits', 'only stage *.cls').",
#   "usage": "dev quickCommit [guidance...]"
# }

source ~/.bashrc.local
myclaude --dangerously-skip-permissions --verbose --output-format stream-json -p "/quick-commit $*" | jq -r 'select(.type == "assistant") | .message.content[] | select(.type == "text") | .text'
