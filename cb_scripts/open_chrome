# {
#   "name": "open_chrome",
#   "description": "Open the default org in chrome browser",
#   "usage": "dev open_chrome"
# }
alias=$1

if [ -z $alias ]; then
    alias=$DefaultAlias
fi

url=$(sf org open -o $alias --url-only --json 2>/dev/null | python3 -c "import sys,json; print(json.load(sys.stdin)['result']['url'])")
echo "$url"
open -a "Google Chrome" "$url"
