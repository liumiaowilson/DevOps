# {
#   "name": "save_madou_movie_auto",
#   "description": "Iterate top-level files in a folder (alphabetical) and run save_madou_movie for each, retrying each file (same params) on transient failures before aborting. Records progress in a sidecar file so re-running the same folder resumes where it left off. Pass 'remote' to route madou requests through compute automation",
#   "usage": "dev save_madou_movie_auto <folder> [remote]"
# }
dir=$1
mode=$2                         # optional: 'remote' to use compute automation for madou requests

maxAttempts=3                   # retry save_madou_movie (same params) on transient failures
retryDelay=5                    # seconds to wait between attempts

if [ -z "$dir" ]; then
    echo 'Folder is required'
    exit 1
fi

absDir=$(cd "$dir" 2>/dev/null && pwd)
if [ -z "$absDir" ]; then
    echo "Folder does not exist: $dir"
    exit 1
fi

# Sidecar progress file: one absolute file path per successfully processed file.
# Re-running the same folder skips paths already listed here.
progressFile="$absDir/.save_madou_movie_auto.done"
touch "$progressFile"

# Count top-level regular files for progress reporting (excludes the sidecar).
total=0
for f in "$absDir"/*; do
    [ -f "$f" ] || continue
    [ "$f" = "$progressFile" ] && continue
    total=$((total + 1))
done

current=0
processed=0
skipped=0

for f in "$absDir"/*; do
    [ -f "$f" ] || continue
    [ "$f" = "$progressFile" ] && continue
    current=$((current + 1))

    if grep -Fxq "$f" "$progressFile"; then
        skipped=$((skipped + 1))
        echo "[$current/$total] Skipping (already done): $f"
        continue
    fi

    echo ""
    echo "[$current/$total] Saving: $f"

    attempt=1
    ok=0
    while [ "$attempt" -le "$maxAttempts" ]; do
        if [ "$attempt" -gt 1 ]; then
            echo "[$current/$total] Retry $attempt/$maxAttempts (waiting ${retryDelay}s): $f"
            sleep "$retryDelay"
        fi
        if dev save_madou_movie "$f" "$mode"; then
            ok=1
            break
        fi
        echo "[$current/$total] Attempt $attempt/$maxAttempts failed: $f"
        attempt=$((attempt + 1))
    done

    if [ "$ok" -ne 1 ]; then
        echo "[$current/$total] Failed after $maxAttempts attempt(s): $f"
        echo "Aborting — save_madou_movie errored out."
        exit 1
    fi
    echo "$f" >> "$progressFile"
    processed=$((processed + 1))
    echo "[$current/$total] Done: $f"
done

echo ""
echo "Finished. Processed $processed, skipped $skipped, of $total file(s)."
