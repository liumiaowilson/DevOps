# {
#   "name": "save_phub_movie",
#   "description": "Look up the PHubQueueItem record matching a downloaded movie's filename to recover its page URL, scrape the pornhub poster + title, upload the poster to pCloud, summarize/describe/probe the local file, and create a Movie Item__c record. Pass 'remote' to route pornhub requests through compute automation",
#   "usage": "dev save_phub_movie <path/to/movie.mp4> [remote]"
# }
filePath=$1
mode=$2                         # optional: 'remote' to use compute automation for pornhub requests

if [ -z "$filePath" ]; then
    echo 'Movie file path is required'
    exit 1
fi

sf mypim run script -o mypim -f ~/DevOps/cb_js/save_phub_movie.js "$filePath" "$mode"
