# {
#   "name": "quickCommit",
#   "description": "Stage all changes and commit with an auto-generated message. Optional free-form guidance steers style, tone, or staging (e.g., 'be terse', 'use conventional commits', 'only stage *.cls').",
#   "usage": "dev quickCommit [guidance...]"
# }

source ~/.bashrc.local

guidance="$*"
if [ -z "$guidance" ]; then
  dir="$PWD"
  while true; do
    if [ -f "$dir/git_init.sh" ]; then
      guidance="use a simple summary as the commit message"
      break
    fi
    [ "$dir" = "/" ] && break
    dir="$(dirname "$dir")"
  done
fi

myclaude --dangerously-skip-permissions --verbose --output-format stream-json -p "/quick-commit $guidance" | jq -r 'select(.type == "assistant") | .message.content[] | select(.type == "text") | .text'
