# {
#   "name": "save_manga",
#   "description": "Download an e-hentai gallery to pCloud and create Manga Item__c records",
#   "usage": "dev save_manga <galleryUrl> [alias]"
# }
galleryUrl=$1
alias=${2:-$DefaultAlias}

if [ -z "$galleryUrl" ]; then
    echo 'Gallery URL is required'
    exit 1
fi

sf mypim run script -o $alias -f ~/DevOps/cb_js/save_manga.js "$galleryUrl"
