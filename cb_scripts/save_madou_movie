filePath=$1
alias=${2:-$DefaultAlias}

if [ -z "$filePath" ]; then
    echo 'Movie file path is required'
    exit 1
fi

sf mypim run script -o "$alias" -f ~/DevOps/cb_js/save_madou_movie.js "$filePath"
