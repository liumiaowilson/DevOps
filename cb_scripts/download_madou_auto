# {
#   "name": "download_madou_auto",
#   "description": "Process the oldest N queued PasteItem records: for each, query the madou page URL from the mypim org, run dev download_madou on it, and delete the record on success. Aborts when the queue is empty or a step fails.",
#   "usage": "dev download_madou_auto [N]"
# }
alias=mypim
N=${1:-1}

if ! [[ "$N" =~ ^[1-9][0-9]*$ ]]; then
    echo "Error: N must be a positive integer (got: '$N')"
    exit 1
fi

# Retry an org/sf operation up to 3 times with a 5s pause between attempts.
retry() {
    local attempt=1
    while :; do
        "$@" && return 0
        if [ "$attempt" -ge 3 ]; then
            return 1
        fi
        echo "  Attempt $attempt failed; retrying in 5s..." >&2
        sleep 5
        attempt=$((attempt+1))
    done
}

queryOldest() {
    sf data query \
        -q "SELECT Id, Answer__c FROM Item__c WHERE Type__c = 'PasteItem' ORDER BY CreatedDate ASC LIMIT 1" \
        -o "$alias" --json
}

deleteRecord() {
    sf data delete record -s Item__c -i "$1" -o "$alias" --json
}

i=0
while [ "$i" -lt "$N" ]; do
    i=$((i+1))
    echo "===== [$i/$N] $(date '+%Y-%m-%d %H:%M:%S') ====="

    result=$(retry queryOldest)
    if [ $? -ne 0 ]; then
        echo "Query failed after retries; aborting."
        exit 1
    fi

    totalSize=$(printf '%s' "$result" | jq -r '.result.totalSize')
    if [ "$totalSize" = "0" ] || [ -z "$totalSize" ] || [ "$totalSize" = "null" ]; then
        echo "No more PasteItem records; done."
        exit 0
    fi

    recordId=$(printf '%s' "$result" | jq -r '.result.records[0].Id')
    madou_url=$(printf '%s' "$result" | jq -r '.result.records[0].Answer__c')

    echo "Record:   $recordId"

    if [ -z "$madou_url" ] || [ "$madou_url" = "null" ]; then
        echo "Record $recordId has an empty madou URL; aborting (record kept)."
        exit 1
    fi

    if ! sh "$ScriptsDir/download_madou" "$madou_url"; then
        echo "download_madou failed for $madou_url; aborting (record kept)."
        exit 1
    fi

    if ! retry deleteRecord "$recordId"; then
        echo "Failed to delete record $recordId after retries; aborting."
        exit 1
    fi
    echo "Deleted:  $recordId"
done

echo "Reached N=$N iterations; stopping."
