#!/bin/bash
PIDFILE="$HOME/.chrome-debug-profile/.pid"

if [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null; then
  echo "Debug Chrome is already running (PID $(cat "$PIDFILE"))"
  exit 1
fi

# Fresh profile with theme
rm -rf "$HOME/.chrome-debug-profile"
mkdir -p "$HOME/.chrome-debug-profile/Default"
echo '{"browser":{"theme":{"color_variant2":1,"user_color2":-806210}}}' \
  > "$HOME/.chrome-debug-profile/Default/Preferences"

# Prefer Chrome Canary, fall back to regular Chrome
CANARY="/Applications/Google Chrome Canary.app/Contents/MacOS/Google Chrome Canary"
CHROME="/Applications/Google Chrome.app/Contents/MacOS/Google Chrome"

if [ -x "$CANARY" ]; then
  BROWSER="$CANARY"
else
  BROWSER="$CHROME"
fi

"$BROWSER" \
  --remote-debugging-port=9222 \
  --user-data-dir="$HOME/.chrome-debug-profile" &>/dev/null &
echo $! > "$HOME/.chrome-debug-profile/.pid"
echo "Debug Chrome started (PID $!)"
